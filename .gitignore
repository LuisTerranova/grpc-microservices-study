## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the TestResults folder
#TestResults/

# VS Code
.vscode/

# Rider / IntelliJ / JetBrains
.idea/
*.sln.iml
*.user
*.userosscache
*.sln.doccache

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Aspire
.aspire/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.doccache
*.sublime-project
*.sublime-workspace

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image-cache files
Thumbs.db
ehthumbs.db

# Folder config files
Desktop.ini

# Recycled Folder
$RECYCLE.BIN/

# Others
publish/
forpublish/
node_modules/
.DS_Store
